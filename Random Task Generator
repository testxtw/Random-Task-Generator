import tkinter as tk
from tkinter import ttk, messagebox
import random
import json
import os

# Константы
TASKS_FILE = "tasks.json"
DEFAULT_TASKS = [
    {"text": "Прочитать статью", "type": "учёба"},
    {"text": "Сделать зарядку", "type": "спорт"},
    {"text": "Написать отчёт", "type": "работа"},
]

class TaskGeneratorApp:
    def __init__(self, root):
        self.root = root
        self.root.title("Генератор случайных задач")
        self.tasks = []
        self.history = []
        self.filter_type = tk.StringVar(value="все")

        self.load_tasks()
        self.create_widgets()

    def create_widgets(self):
        # Фильтр по типу задачи
        ttk.Label(self.root, text="Фильтр по типу:").grid(row=0, column=0, padx=10, pady=5, sticky="e")
        type_options = ["все", "учёба", "спорт", "работа"]
        # Используем ttk.Combobox (рекомендация)
        self.filter_combo = ttk.Combobox(self.root, textvariable=self.filter_type, values=type_options, state="readonly")
        self.filter_combo.grid(row=0, column=1, padx=10, pady=5)

        # Кнопка генерации
        self.generate_btn = ttk.Button(self.root, text="Сгенерировать задачу", command=self.generate_task)
        self.generate_btn.grid(row=1, column=0, columnspan=2, pady=10)

        # Поле вывода задачи
        self.task_label = ttk.Label(self.root, text="", font=("Arial", 12), wraplength=300)
        self.task_label.grid(row=2, column=0, columnspan=2, pady=10)

 
